{
  "name": "agnes-ai-studio-web",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=24.3.0 <25",
    "npm": ">=10 <12"
  },
  "packageManager": "npm@11.4.2",
  "browserslist": {
    "production": ["Chrome >= 109", "Edge >= 109", "Firefox >= 115", "Safari >= 16", "not dead"],
    "development": ["last 1 Chrome version", "last 1 Firefox version", "last 1 Safari version"]
  },
  "scripts": {
    "dev": "node ../scripts/clean-next-cache.mjs && next dev -p 3001",
    "dev:turbopack": "node ../scripts/clean-next-cache.mjs && next dev --turbopack -p 3001",
    "build": "next build",
    "start": "next start -p 3001",
    "lint": "tsc --noEmit",
    "test:e2e": "node scripts/run-smoke-e2e.mjs",
    "test:e2e:prepared": "node scripts/run-smoke-e2e.mjs --skip-build",
    "test:e2e:legacy": "playwright test --reporter=line"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.4.0",
    "@radix-ui/react-alert-dialog": "^1.1.19",
    "@radix-ui/react-dialog": "^1.1.19",
    "@radix-ui/react-dropdown-menu": "^2.1.20",
    "@radix-ui/react-label": "^2.1.11",
    "@radix-ui/react-popover": "^1.1.19",
    "@radix-ui/react-scroll-area": "^1.2.14",
    "@radix-ui/react-select": "^2.3.3",
    "@radix-ui/react-separator": "^1.1.11",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-tabs": "^1.1.0",
    "@radix-ui/react-toggle": "^1.1.14",
    "@radix-ui/react-toggle-group": "^1.1.15",
    "@radix-ui/react-tooltip": "^1.2.12",
    "@tiptap/extension-character-count": "^2.6.0",
    "@tiptap/extension-focus": "^2.6.0",
    "@tiptap/extension-highlight": "^2.6.0",
    "@tiptap/extension-placeholder": "^2.6.0",
    "@tiptap/extension-text-align": "^2.6.0",
    "@tiptap/extension-underline": "^2.6.0",
    "@tiptap/pm": "^2.6.0",
    "@tiptap/react": "^2.6.0",
    "@tiptap/starter-kit": "^2.6.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "lucide-react": "^0.468.0",
    "next": "^15.3.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.81.0",
    "tailwind-merge": "^2.5.5",
    "zod": "^4.4.3",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.51.1",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.1",
    "@types/react-dom": "^19.0.2",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.16",
    "typescript": "^5.7.2"
  }
}
