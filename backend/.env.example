AGNES_API_KEY=your_agnes_api_key_here
AGNES_API_BASE_URL=https://apihub.agnes-ai.com

# 默认仅允许本机访问。需要局域网部署时必须同时配置认证与防火墙。
HOST=127.0.0.1
# 允许调用后端的浏览器来源，多个值用逗号分隔。
CORS_ALLOWED_ORIGINS=http://127.0.0.1:3001,http://localhost:3001

# === P0 安全发布配置 ===
# 生产环境必须使用 32 字节随机密钥（base64 或 64 位 hex），并与 SQLite 数据文件分离保管。
# DATA_ENCRYPTION_KEY=replace_with_32_byte_base64_key
# 密钥轮换时临时保留旧 key，多个值用逗号分隔；数据重写完成后移除。
# DATA_ENCRYPTION_PREVIOUS_KEYS=old_key_base64
# 生产默认强制 HTTPS；仅在受信反向代理后开启 TRUST_PROXY。
# FORCE_HTTPS=true
# TRUST_PROXY=true
# 远程媒体域名精确白名单；留空仍会执行 HTTPS + DNS/IP 私网阻断。
# REMOTE_MEDIA_ALLOWED_HOSTS=cdn.example.com,media.example.com
# 生产上传默认要求 ClamAV INSTREAM 服务。显式设 false 表示已由风险负责人接受无 AV 风险。
# CLAMAV_HOST=127.0.0.1
# CLAMAV_PORT=3310
# UPLOAD_AV_REQUIRED=true

# === 登录、会话与权限 ===
# 本机单用户调试可设 disabled；任何非回环地址默认强制 required。
AUTH_MODE=required
# 仅首次初始化管理员时读取，至少 12 位；初始化后修改此值不会重置数据库密码。
AUTH_ADMIN_USERNAME=admin
AUTH_ADMIN_PASSWORD=replace_with_a_long_random_password
AUTH_ADMIN_DISPLAY_NAME=系统管理员
AUTH_ORGANIZATION_NAME=默认组织
# 仅在 HTTPS 部署时开启，否则浏览器不会发送本地 HTTP Cookie。
AUTH_COOKIE_SECURE=false

# Optional overrides. Keep default values unless Agnes official docs change.
AGNES_CHAT_PATH=/v1/chat/completions
AGNES_IMAGE_PATH=/v1/images/generations
AGNES_VIDEO_PATH=/v1/videos
AGNES_VIDEO_TASK_PATH=/agnesapi?video_id=:taskId

# === 智谱 AI 配置（可选）===
# 用于 glm-* / zhipu-* 模型路由
# ZHIPU_API_KEY=your_zhipu_api_key_here

# === Cerebras 配置（可选）===
# 用于 cerebras-* 模型路由
# CEREBRAS_API_KEY=your_cerebras_api_key_here
# CEREBRAS_API_BASE_URL=https://api.cerebras.ai/v1
# CEREBRAS_PROXY_URL=http://127.0.0.1:7897

# === 商汤 SenseNova 配置（可选）===
# 用于 sensenova-* 模型路由
# SENSENOVA_API_KEY=your_sensenova_api_key_here
# SENSENOVA_API_BASE_URL=https://token.sensenova.cn/v1
# SENSENOVA_PROXY_URL=http://127.0.0.1:7897
