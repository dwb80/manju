{
  "name": "backend",
  "version": "1.0.0",
  "description": "Agnes AI Studio Backend",
  "main": "dist/main.js",
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "start:dev": "npm run build && node dist/server.js",
    "test": "npm run build && node --test tests/*.test.mjs",
    "test:all": "npm test && npm run frontend:build && npm run frontend:test:e2e",
    "frontend:dev": "npm --prefix ../frontend run dev",
    "frontend:build": "npm --prefix ../frontend run build",
    "frontend:start": "npm --prefix ../frontend run start",
    "frontend:test:e2e": "npm --prefix ../frontend run test:e2e"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "sharp": "^0.35.3"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.0"
  }
}
